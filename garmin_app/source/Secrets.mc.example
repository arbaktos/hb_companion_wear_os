// Copy to Secrets.mc (gitignored) and fill in. Real values: ../LOCAL_NOTES.md.
// NOTE: Garmin must use the PUBLIC-TLS endpoint (:8443, Let's Encrypt) — the
// pinned self-signed :8001 endpoint will be rejected by Garmin's trust store.

module Secrets {
    const BASE_URL = "https://<vm-ip-dashed>.nip.io:8443";
    const TOKEN = "<API_BEARER_TOKEN from /etc/baby-svc.env>";
}
